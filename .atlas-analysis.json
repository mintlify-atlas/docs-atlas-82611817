  "keyFeatures": [
    "One-command scaffold via `npx claude-second-brain`",
    "Claude Code slash commands for ingest, search, lint, and maintenance",
    "Local hybrid semantic search (vector + BM25) powered by qmd",
    "Scaffolded vault is a ready-to-use Obsidian vault with obsidian-git pre-configured",
    "GitHub as source of truth with anywhere access via Claude Code and Obsidian mobile",
    "Five structured wiki page types with YAML frontmatter",
    "Automatic contradiction flagging and cross-linking"
  ],
  "publicApiSurface": [
    "npx claude-second-brain [folder-name]",
    "/brain-ingest — ingest a source into the wiki",
    "/brain-search — hybrid semantic search and cited answers",
    "/brain-refresh — re-index changed files",
    "/brain-rebuild — destructively redesign the qmd schema",
    "/lint — health-check orphans, broken links, contradictions",
    "/setup — first-time qmd initialization",
    "bin/create.js — CLI entry point",
    "template/ — vault scaffold template"
